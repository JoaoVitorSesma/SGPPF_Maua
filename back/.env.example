# Configurações Gerais
API_V1_STR=/api/v1
PROJECT_NAME="SGPPF - Sistema de Gestão de Projetos, Publicações e Financiamentos"
# Opcional: por padrao, o SQLite fica em %LOCALAPPDATA%\SGPPF\sgppf.db no Windows.
# SQLALCHEMY_DATABASE_URI=postgresql://usuario:senha@localhost:5432/sgppf

# Segurança
SECRET_KEY=super-secret-key-change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=11520 # 8 days

# OAuth - Microsoft (Azure AD)
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_TENANT_ID=common

# OAuth - Google
GOOGLE_CLIENT_ID=your-google-client-id
